---
import PlayerLayout from "../../layouts/PlayerLayout.astro";
import { Sidebar } from "../../components/Sidebar";

const sidebarDataUrl = `${import.meta.env.BASE_URL}/api/sidebar-data.json`;
---

<PlayerLayout title="このサイトについて | EtoSora player">
  <Sidebar slot="sidebar" dataUrl={sidebarDataUrl} client:load />

  <div class="flex justify-center w-full">
    <div class="w-full max-w-[90%] mx-auto p-4 sm:p-6 space-y-6 sm:space-y-8">
      <h1 class="text-2xl sm:text-3xl font-bold">このサイトについて</h1>
      <div class="space-y-4 text-base sm:text-lg text-muted-foreground">
        <p>
          これはバーチャルユニット「<a
            class="font-bold text-blue-600 no-underline"
            href="https://www.youtube.com/@etosora">エトソラ</a
          >」の YouTube
          ライブ配信のうち歌枠のアーカイブを再生するための非公式
          Web サイトです。
        </p>
        <p>
          再生を開始するには、サイドバーの "Archives"
          タブから動画を選んでください。"Songs"
          タブから曲を選ぶと、その曲を歌ったアーカイブ動画の一覧が表示されます。
        </p>
        <p>
          本サイトは GitHub の <a
            href="https://github.com/6r-rd/etosora-player"
            target="_blank"
            class="text-blue-600 hover:underline">6r-rd/etosora-player</a
          > という public リポジトリで開発および運用されています。ご意見やご指摘は
          GitHub Issues にてご連絡ください。
        </p>
      </div>
      <h2 class="text-xl sm:text-2xl font-bold">エトソラについて</h2>
      <div class="space-y-4 text-base sm:text-lg text-muted-foreground">
        <ul>
          <li>
            公式 YouTube チャンネル <a
              href="https://www.youtube.com/@etosora"
              target="_blank"
              class="text-blue-600 hover:underline">https://www.youtube.com/@etosora</a
            >
          </li>
          <li>
            公式 X アカウント <a
              href="https://x.com/etosora_info"
              target="_blank"
              class="text-blue-600 hover:underline">https://x.com/etosora_info</a
            >
          </li>
        </ul>
      </div>
      <div></div>
    </div>
  </div>
</PlayerLayout>
